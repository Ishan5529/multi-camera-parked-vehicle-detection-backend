# Server configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
PORT=8000
DEBUG=False

# Application settings
APP_NAME=Multi-Camera Parked Vehicle Detection API
LOG_LEVEL=info

# Database
# Local fallback if DATABASE_URL is not set: sqlite:///./app.db
# Render PostgreSQL example:
# DATABASE_URL=postgresql://user:password@host:5432/database
DATABASE_URL=

# CORS configuration
# Use comma-separated origins in production, for example:
# CORS_ORIGINS=https://your-frontend.onrender.com,https://yourdomain.com
CORS_ORIGINS=*
CORS_ALLOW_CREDENTIALS=False
